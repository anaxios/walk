#!/usr/bin/env bash

is_dir() { [[ -d "$1" ]]; }
is_set() { [[ -n "$1" ]]; }
is_empty_array() { [[ 0 == "${#@}" ]]; }

write() {
    if is_set "$NULL_TERMINATED"; then
        printf '%s\0' "$1"
    else
        printf '%s\n' "$1"
    fi
}


